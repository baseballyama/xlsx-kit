{
  "name": "openxml-js",
  "version": "0.0.0",
  "description": "TypeScript port of openpyxl: read/write Excel xlsx in Node and the browser.",
  "type": "module",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "dist/**",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./streaming": {
      "types": "./dist/streaming/index.d.ts",
      "import": "./dist/streaming.mjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "bench": "vitest bench --run tests/perf/throughput.bench.ts",
    "build": "tsdown && tsc -p tsconfig.build.json",
    "build:js": "tsdown",
    "build:dts": "tsc -p tsconfig.build.json",
    "size": "size-limit",
    "doc:api": "typedoc"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^3.23.2",
    "oxlint": "^1.62.0",
    "size-limit": "^12.1.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2",
    "saxes": "^6.0.0"
  }
}
