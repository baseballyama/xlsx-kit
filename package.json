{
  "name": "openxml-js",
  "version": "0.0.0",
  "description": "TypeScript port of openpyxl: read/write Excel xlsx in Node and the browser.",
  "type": "module",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "dist/**",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:js": "tsup",
    "build:dts": "tsc -p tsconfig.build.json",
    "size": "size-limit",
    "doc:api": "typedoc"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2"
  }
}
